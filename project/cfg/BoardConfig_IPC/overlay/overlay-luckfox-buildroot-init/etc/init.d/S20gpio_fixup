#!/bin/sh
#
# S20gpio_fixup - Apply GPIO pull-up fixups at boot
#
# On the Pico Pro Max, GPIO1_C4 (KEY_PRESS) defaults to pull-down at reset.
# The DT pcfg_pull_up_ie hog entry should set pull-up at boot, but a timing
# issue between the pinctrl hog and the GPIO bank probe leaves the pull
# register at its reset default.  Writing the IOC register directly fixes it.
#
# Register: GPIO1_IOC PULL (0xFF5381C8)
#   bits[31:16] = write-enable mask, bits[15:0] = data
#   C4 pull bits = [9:8], value 01 = pull-up
#   0x03000100 -> mask bits 9:8, set to 01 (pull-up)
#

case "$1" in
start)
	model=""
	if [ -f /proc/device-tree/model ]; then
		model=$(cat /proc/device-tree/model | tr -d '\0')
	fi

	case "$model" in
	*Pro\ Max*|*Pico\ Max*)
		# GPIO1_C4 (KEY_PRESS) pull-up
		io -4 0xFF5381C8 0x03000100
		;;
	esac
	;;
*)
	;;
esac
